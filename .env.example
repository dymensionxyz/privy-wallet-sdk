# Privy (get from https://dashboard.privy.io)
VITE_PRIVY_APP_ID=your-privy-app-id

# Anvil local deployment — run: forge script script/DeployLocal.s.sol --tc DeployLocal --rpc-url $RPC_URL --broadcast --private-key $DEPLOYER_PRIVATE_KEY
# These addresses match the deterministic output of DeployLocal.s.sol on a fresh Anvil instance.
VITE_RPC_URL=http://127.0.0.1:8545
VITE_VAULT_ADDRESS=0x9fE46736679d2D9a65F0992F2272dE9f3c7fa6e0
VITE_USDC_ADDRESS=0x5FbDB2315678afecb367f032d93F642f64180aa3

# Backend server URL for test validation (e.g. http://localhost:8080)
# VITE_SERVER_URL=http://localhost:8080

